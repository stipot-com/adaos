# Example environment for local development.
# Copy this file to `.env` and adjust only the values you need.
#
# Base directory selection:
# - `ENV_TYPE=dev` uses repo-local `.adaos/`
# - empty or `ENV_TYPE=prod` uses `~/.adaos/`
#
# For production-like hub hosts, start from `.env.prod.sample` instead.

# === Core runtime ===
# Set to `dev` for repo-local development. Leave empty for the default home-based layout.
ENV_TYPE=
# Default UI and CLI language (`en` or `ru`).
ADAOS_LANG=en
# Active AdaOS profile name.
ADAOS_PROFILE=default
# Absolute override for the AdaOS base directory.
ADAOS_BASE_DIR=
# Optional suffix for repo-local `.adaos` in dev mode.
ADAOS_BASE_DIR_SUFFIX=
# Legacy fallback base directory override.
BASE_DIR=

# Root bootstrap/admin token used by development helpers.
ADAOS_ROOT_OWNER_TOKEN=dev-root-token
ROOT_TOKEN=dev-root-token
# Backend zone identifier for zone-aware deployments, for example `ru` or `de`.
ADAOS_ZONE_ID=
# Default bot identifier used by local integrations.
BOT_ID=adaos_bot

# === Logging and diagnostics ===
# Set to `1` to print stack traces in CLI commands.
ADAOS_CLI_DEBUG=0
# Global log level.
ADAOS_LOG_LEVEL=DEBUG
# Scenario runtime log level.
ADAOS_SCENARIO_LOG_LEVEL=INFO
# Set to `1` to enable test-only shortcuts and mocks.
ADAOS_TESTING=0
# Optional file path touched when services become ready.
ADAOS_READY_PATH=

# === Build metadata ===
# Optional override for Git-derived build version, usually set in CI.
ADAOS_BUILD_VERSION=
# Optional build timestamp in ISO 8601 format.
ADAOS_BUILD_DATE=
# Base semantic version used when deriving build numbers.
ADAOS_BASE_VERSION=0.1.0

# === SDK and skills ===
# Comma-separated modules allowed for SDK exporter override.
ADAOS_SDK_EXPORT_MODULES=
# Path to a custom skill virtual environment.
ADAOS_SKILL_ENV_PATH=
# Prefix for on-demand skill test virtual environments.
ADAOS_SKILL_TEST_ENV_PREFIX=
# Set to `1` to allow custom monorepo URLs and branches.
ADAOS_ALLOW_UNSAFE_MONOREPO=0
# Custom skills monorepo URL.
ADAOS_SKILLS_MONOREPO_URL=
# Custom skills monorepo branch.
ADAOS_SKILLS_MONOREPO_BRANCH=
# Custom scenarios monorepo URL.
ADAOS_SCENARIOS_MONOREPO_URL=
# Custom scenarios monorepo branch.
ADAOS_SCENARIOS_MONOREPO_BRANCH=

# === Testing and sandbox ===
# Minimum Python version required by the test suite.
ADAOS_MIN_PY=3.11
# Specific Python executable for tests, for example `python3.11`.
ADAOS_TEST_PY=
# Set to `1` to disable sandbox execution.
ADAOS_SANDBOX_DISABLED=0

# === Local API bridge ===
# Base URL for the local AdaOS HTTP API.
# Keep this aligned with the port you want browser-side tooling to discover by default.
# Common values:
# - `8777`: default direct dev runtime
# - `8778`: second slot in supervisor-managed mode
# - `8779`: local dev runtime that should stay hidden from browser auto-discovery
ADAOS_BASE=http://127.0.0.1:8777
# Token used for local API calls.
ADAOS_TOKEN=dev-local-token
# Optional override for the AdaOS launch command.
ADAOS_CMD=
# Gateway port exposed by the local AdaOS bridge.
ADAOS_GW_PORT=8777
# Target host used when tunneling traffic.
ADAOS_TARGET_HOST=127.0.0.1
# Target port used when tunneling traffic.
ADAOS_TARGET_PORT=8777
# Internal launch mode marker. `api serve` sets this to `api_serve` automatically.
# Leave empty unless you are reproducing runtime startup behavior manually.
ADAOS_RUNTIME_LAUNCH_MODE=
# Internal self-advertised local API base. `api serve` sets this automatically at runtime.
ADAOS_SELF_BASE_URL=

# === Speech and voice ===
# Rhasspy base URL.
ADAOS_RHASSPY_URL=http://127.0.0.1:12101
# Docker container name for the Rhasspy helper.
ADAOS_RHASSPY_CONTAINER=adaos-rhasspy
# Rhasspy image reference.
ADAOS_RHASSPY_IMAGE=rhasspy/rhasspy:latest
# Host port for the Rhasspy UI and API.
ADAOS_RHASSPY_PORT=12101
# Rhasspy profile or language code.
ADAOS_RHASSPY_PROFILE=en
# Host directory for Rhasspy data.
ADAOS_RHASSPY_DATA=~/.config/rhasspy
# Optional mirror URL for Vosk models.
ADAOS_VOSK_MIRROR=
# Local path or URL to a pre-downloaded Vosk archive.
ADAOS_VOSK_ZIP=

# === Messaging and storage ===
# MQTT broker hostname.
MQTT_HOST=mqtt
# MQTT broker port.
MQTT_PORT=1883
# Path to the SQLite database with skills metadata.
SQLITE_PATH=/app/skill_db.sqlite

# === Git identity ===
# Default author name for generated commits.
GIT_USER=adaos
# Default author email for generated commits.
GIT_EMAIL=adaos@local

# === Platform-specific ===
# Internal flag used by Kivy packaging on Android.
KIVY_BUILD=
# Windows-specific override for the local data path.
LOCALAPPDATA=

# === NLU ===
# Set to `1` to allow interpreter auto-training.
ADAOS_INTERPRETER_AUTOTRAIN=1

# === NATS over WebSocket ===
# Transport used by the hub-to-root NATS client (`ws` or `tcp`).
HUB_NATS_TRANSPORT=
# Idle timeout in seconds before the hub considers the NATS WS link dead.
HUB_NATS_RX_TIMEOUT_S=600
# Best-effort raw socket keepalive interval in seconds. Use `0` to disable it.
HUB_NATS_RAW_KEEPALIVE_S=15
# Prefer the auth-compatible API ingress by default.
HUB_NATS_PREFER_DEDICATED=0
# WebSocket client implementation (`websockets` or `aiohttp`).
HUB_NATS_WS_IMPL=websockets
# Client-side WebSocket heartbeat interval in seconds. Keep `0` unless you need it.
HUB_NATS_WS_HEARTBEAT_S=0
# Client-side NATS ping interval task. Keep disabled for WS unless you are explicitly
# testing client-initiated NATS keepalives end-to-end.
HUB_NATS_DISABLE_PING_INTERVAL_TASK=1
# NATS client ping interval and max outstanding pings, used only when the interval task
# is enabled or for compatibility with some environments.
HUB_NATS_PING_INTERVAL_S=15
HUB_NATS_MAX_OUTSTANDING_PINGS=2
# Hub-to-root NATS data heartbeat interval in seconds. Leave empty by default:
# on Windows/websockets an extra standalone `PONG\r\n` data heartbeat can interfere
# with root-side keepalive accounting.
HUB_NATS_WS_DATA_HEARTBEAT_S=
# Optional recv timeout for WS transports. Leave empty unless you are debugging stalled reads.
HUB_NATS_WS_RECV_TIMEOUT_S=
# Close stale route keys after this many seconds without an upstream connection.
HUB_ROUTE_FORCE_CLOSE_NO_UPSTREAM_S=1.5
# Warn when a route reply publish itself takes longer than this.
HUB_ROUTE_PUBLISH_SLOW_WARN_S=0.250
# Warn when the oldest pending route key has been waiting at least this long.
HUB_ROUTE_STARVATION_WARN_S=1.000
# Warn when the local NATS client accumulates at least this many pending route bytes.
HUB_ROUTE_PENDING_DATA_WARN_BYTES=262144
# Route key prefixes accepted by the hub route relay. Empty means the active hub id only.
HUB_ROUTE_KEY_PREFIXES=
# Keep expensive synchronous skill snapshot handlers off the asyncio event loop.
ADAOS_SYNC_SUBSCRIPTION_TO_THREAD=1
ADAOS_SYNC_SUBSCRIPTION_THREAD_TOPICS=sys.ready,webio.stream.snapshot.requested
# Capture root/backend log excerpts automatically after NATS/route errors.
HUB_ROOT_LOG_SNAPSHOT=1
HUB_ROOT_LOG_SNAPSHOT_LINES=2000
HUB_ROOT_LOG_SNAPSHOT_AFTER_ERR_S=0,3
HUB_ROOT_LOG_SNAPSHOT_EXTRACT_PRINT=0
HUB_ROOT_LOG_EXTRACT_VERBOSE=0
# Windows-only event loop override used for targeted diagnostics. Leave `0` by default.
ADAOS_WIN_SELECTOR_LOOP=0
# Root-side WS->NATS proxy keepalive. Keep disabled by default for hub WS clients:
# during diagnostics this keepalive path caused reproducible disconnects after ~80s,
# while the tunnel remained stable without it.
WS_NATS_PROXY_KEEPALIVE_ENABLE=0
# If root keepalive is enabled later, require full handshake before sending client PINGs.
WS_NATS_PROXY_KEEPALIVE_REQUIRE_HANDSHAKE=1
# Delay closing superseded hub ws-nats connections for a short grace period so in-flight
# `route.v2.to_browser.*` replies can drain during reconnect/cutover.
WS_NATS_PROXY_SUPERSEDE_GRACE_MS=1500
# Root-side WebSocket PING frames to clients. Keep disabled unless you are explicitly
# testing WS control-frame behavior end-to-end.
WS_NATS_PROXY_WS_PING=0
# Do not terminate client-originated NATS PING locally by default; preserve end-to-end
# NATS flush semantics unless you are testing a targeted workaround.
WS_NATS_PROXY_TERMINATE_CLIENT_PING=0

# === Supervisor / slots ===
# Internal flag set by the slot supervisor. Keep `0` or empty for direct `adaos api serve` development.
ADAOS_SUPERVISOR_ENABLED=0
# Supervisor API port. Production-like slot-managed runtime expects `8776`.
ADAOS_SUPERVISOR_PORT=8776

# === Subnet sync and forwarding ===
# Set to `1` to allow YJS replication to the node.
ADAOS_SUBNET_YJS_REPLICATION=1
# Comma-separated prefixes forwarded from member to hub. Use `*` to forward all.
ADAOS_SUBNET_BUS_FORWARD_PREFIXES=*

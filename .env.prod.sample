# Production-oriented hub defaults (copy to `.env` on the hub host and fill secrets).

# === Core runtime settings ===
ENV_TYPE=prod
ADAOS_LANG=en
ADAOS_PROFILE=default

# Root developer/API token (must match root's ROOT_TOKEN)
ROOT_TOKEN=change-me-long-random

# === Logging & diagnostics ===
ADAOS_CLI_DEBUG=0
ADAOS_SCENARIO_LOG_LEVEL=INFO
ADAOS_LOG_LEVEL=INFO

HUB_NATS_VERBOSE=0
HUB_NATS_TRACE=0
HUB_NATS_TRACE_INPUT=0
HUB_ROUTE_VERBOSE=0
ROUTE_PROXY_VERBOSE=0
HUB_TG_DEBUG=0

# === NATS-over-WebSocket tuning ===
# If the hub is idle, NATS WS can stay connected without delivering messages for minutes.
# This is the hub-side watchdog timeout (seconds) before we assume the connection is dead.
HUB_NATS_RX_TIMEOUT_S=600

# Force raw socket keepalive (best-effort). 0/empty disables.
HUB_NATS_RAW_KEEPALIVE_S=15

# Optional: client-side WS heartbeat (usually not needed; server already pings).
# HUB_NATS_WS_HEARTBEAT_S=0

